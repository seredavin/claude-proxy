map_hash_bucket_size 128;

map $http_x_gateway_key $gw_ok {
    "${GATEWAY_TOKEN}"  1;
    default             0;
}

log_format proxy_fmt '$remote_addr $status $request_method $uri '
                     'req=$request_length resp=$body_bytes_sent '
                     'upstream=$upstream_status t=$request_time';

server {
    listen 9443 ssl;
    http2 on;
    server_name ${PROXY_SERVER_NAME};

    ssl_certificate     /etc/nginx/certs/${PROXY_SSL_CERT};
    ssl_certificate_key /etc/nginx/certs/${PROXY_SSL_KEY};
    ssl_protocols       TLSv1.2 TLSv1.3;

    access_log /var/log/nginx/access.log proxy_fmt;

    client_max_body_size 100m;

    resolver 127.0.0.11 valid=30s ipv6=off;

    location = /healthz {
        access_log off;
        add_header Content-Type text/plain;
        return 200 "ok\n";
    }

    # Префлайт-проверка соединения Claude Code: при старте CLI шлёт на корень
    # запрос БЕЗ токена шлюза (X-Gateway-Key). Если ответить 401, клиент считает
    # шлюз недоступным и падает с "Unable to connect" ещё до первого запроса.
    # Отдаём 200. Реальный трафик идёт на /v1/... и проходит проверку ключа ниже.
    location = / {
        access_log off;
        add_header Content-Type text/plain;
        return 200 "ok\n";
    }

    location / {
        if ($gw_ok = 0) {
            return 401 '{"type":"error","error":{"type":"authentication_error","message":"invalid gateway key"}}';
        }
        if ($http_authorization = "") {
            return 401 '{"type":"error","error":{"type":"authentication_error","message":"missing oauth token"}}';
        }

        set $upstream "api.anthropic.com";
        proxy_pass https://$upstream$request_uri;

        proxy_ssl_server_name on;
        proxy_ssl_name        api.anthropic.com;
        proxy_ssl_verify      on;
        proxy_ssl_trusted_certificate /etc/ssl/certs/ca-certificates.crt;
        proxy_ssl_verify_depth 3;

        proxy_http_version 1.1;
        proxy_set_header Host           api.anthropic.com;
        proxy_set_header Connection     "";
        proxy_set_header X-Gateway-Key  "";

        proxy_buffering         off;
        proxy_request_buffering off;
        proxy_read_timeout      600s;
        proxy_send_timeout      600s;
        proxy_connect_timeout   30s;
    }
}

