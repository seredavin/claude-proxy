map $http_authorization $client_token {
    "~*^Bearer[ ]+(?<token>.+)$"  $token;
    default                       "";
}

log_format proxy_fmt '$remote_addr $status $request_method $uri '
                     'req=$request_length resp=$body_bytes_sent '
                     'upstream=$upstream_status t=$request_time';

server {
    listen 9443 ssl;
    http2 on;
    server_name ${PROXY_SERVER_NAME};

    ssl_certificate     /etc/nginx/certs/${PROXY_SSL_CERT};
    ssl_certificate_key /etc/nginx/certs/${PROXY_SSL_KEY};
    ssl_protocols       TLSv1.2 TLSv1.3;

    access_log /var/log/nginx/access.log proxy_fmt;

    client_max_body_size 100m;

    resolver 127.0.0.11 valid=30s ipv6=off;

    location = /healthz {
        access_log off;
        add_header Content-Type text/plain;
        return 200 "ok\n";
    }

    location / {
        if ($client_token != "${GATEWAY_TOKEN}") {
            return 401 '{"type":"error","error":{"type":"authentication_error","message":"invalid gateway token"}}';
        }

        set $upstream "api.anthropic.com";
        proxy_pass https://$upstream$request_uri;

        proxy_ssl_server_name on;
        proxy_ssl_name        api.anthropic.com;
        proxy_ssl_verify      on;
        proxy_ssl_trusted_certificate /etc/ssl/certs/ca-certificates.crt;
        proxy_ssl_verify_depth 3;

        proxy_http_version 1.1;
        proxy_set_header Host          api.anthropic.com;
        proxy_set_header Connection    "";
        proxy_set_header Authorization "";
        proxy_set_header x-api-key     "${ANTHROPIC_API_KEY}";

        proxy_buffering         off;
        proxy_request_buffering off;
        proxy_read_timeout      600s;
        proxy_send_timeout      600s;
        proxy_connect_timeout   30s;
    }
}

