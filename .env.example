# Режим работы шлюза: apikey | oauth
GATEWAY_MODE=oauth

# Имя, на которое выписан сертификат (или _ для любого)
PROXY_SERVER_NAME=proxy.example.com

# Сертификаты: каталог на хосте и имена файлов внутри него
PROXY_CERTS_DIR=/opt/proxy-certs
PROXY_SSL_CERT=fullchain.pem
PROXY_SSL_KEY=privkey.pem

# --- только для GATEWAY_MODE=apikey ---
# Настоящий ключ Anthropic. Живёт ТОЛЬКО здесь, на хосте прокси. Нужно только для apikey режима
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME

# Токен, который будут предъявлять внутренние клиенты.
# Сгенерировать: openssl rand -hex 32
GATEWAY_TOKEN=REPLACE_ME_WITH_RANDOM_HEX_64
